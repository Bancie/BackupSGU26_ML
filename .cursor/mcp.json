{
  "mcpServers": {
    "pandas-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${workspaceFolder}/tools/mcp/pandas-mcp-server",
        "pandas-mcp-server"
      ]
    },
    "mcp-server-ds": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${workspaceFolder}/tools/mcp/mcp-server-data-exploration",
        "mcp-server-ds"
      ]
    },
    "eda-faiss": {
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["${workspaceFolder}/mcp/eda.py"]
    },
    "ptdl-khaosatbds-faiss": {
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["${workspaceFolder}/mcp/PTDL_khaosatbds.py"]
    }
  }
}
